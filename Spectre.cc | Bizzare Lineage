local ESP_INSTANCES = {}
local STAND_CACHE = {} -- Caches decoded stand names to avoid redundant JSONDecode calls

-- Memory cleanup for stand cache periodically
task.spawn(function()
    while task.wait(60) do
        STAND_CACHE = {} 
    end
