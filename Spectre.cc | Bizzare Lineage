local TpGroup = Tabs.Main:AddRightGroupbox('Teleports')

local VOID_Y = 0.001
local RANDOM_RADIUS = 100
local TELEPORT_INTERVAL = 0.05
local savedCFrame, voidMode, loopCoroutine

local function getChar()
    character = localPlayer.Character
    if character then rootPart = character:FindFirstChild("HumanoidRootPart") end
    return rootPart ~= nil
end

local function randomPos()
    local radius = Options.VoidRadius and Options.VoidRadius.Value or 100
    return vector3New((math.random()*2-1)*radius, VOID_Y, (math.random()*2-1)*radius)
end

local function enterVoid()
    if not getChar() then return end
    savedCFrame = rootPart.CFrame
    rootPart.CFrame = cFrameNew(0, VOID_Y, 0) * CFrame.Angles(math.rad(90), 0, 0)
    rootPart.Velocity, rootPart.RotVelocity = vector3New(), vector3New()
    voidMode = true
    loopCoroutine = coroutine.create(function()
        while voidMode and getChar() do
            rootPart.CFrame = cFrameNew(randomPos()) * CFrame.Angles(math.rad(90), 0, 0)
            local interval = Options.VoidInterval and Options.VoidInterval.Value or 0.05
            task.wait(interval)
        end
    end)
    coroutine.resume(loopCoroutine)
end

local function exitVoid()
    if not getChar() or not savedCFrame then return end
    voidMode = false
    rootPart.CFrame = savedCFrame
    savedCFrame = nil
end

