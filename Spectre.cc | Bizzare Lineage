local function createESP(player)
    if player == localPlayer then return end
    
    local esp = {
        box = {},
        name = Drawing.new("Text"),
        flags = {
            level = Drawing.new("Text"),
            stand = Drawing.new("Text"),
            style = Drawing.new("Text"),
            subability = Drawing.new("Text")
        },
        healthBar = Drawing.new("Line"),
        healthFill = Drawing.new("Line"),
        highlight = Instance.new("Highlight")
    }
    
    esp.healthBar.Thickness = 3
    esp.healthBar.Transparency = 1
    esp.healthBar.Visible = false
    esp.healthFill.Thickness = 1.5
    esp.healthFill.Transparency = 1
    esp.healthFill.Visible = false
    
    esp.highlight.Parent = currentCamera -- Persistent container
    esp.highlight.Enabled = false
    
    local function setupHighlight(char)
        if char then
            esp.highlight.Adornee = char
        end
    end
    
    setupHighlight(player.Character)
    esp.charConn = player.CharacterAdded:Connect(setupHighlight)
    
    -- 12 lines for 3D box
    for i = 1, 12 do
        esp.box[i] = Drawing.new("Line")
        esp.box[i].Thickness = 1.5
        esp.box[i].Transparency = 1
    end
    
    esp.name.Size = 16
    esp.name.Center = true
    esp.name.Outline = true
    esp.name.Font = Drawing.Fonts.Monospace
    
    for _, f in pairs(esp.flags) do
        f.Size = 13
        f.Center = true
        f.Outline = true
        f.Font = Drawing.Fonts.Monospace
    end
    
    ESP_INSTANCES[player] = esp
end

local function removeESP(player)
    local esp = ESP_INSTANCES[player]
    if esp then
        for i = 1, 12 do esp.box[i]:Remove() end
        esp.name:Remove()
        for _, f in pairs(esp.flags) do f:Remove() end
        if esp.healthBar then esp.healthBar:Remove() end
        if esp.healthFill then esp.healthFill:Remove() end
        if esp.highlight then esp.highlight:Destroy() end
        if esp.charConn then esp.charConn:Disconnect() end
        ESP_INSTANCES[player] = nil
    end
end

for _, player in ipairs(players:GetPlayers()) do createESP(player) end
connections.PlayerAdded = players.PlayerAdded:Connect(createESP)
connections.PlayerRemoving = players.PlayerRemoving:Connect(removeESP)

local function getCorners3D(cframe, size)
    local hw = size.X / 2
    local hh = size.Y / 2
    local hd = size.Z / 2
    
    return {
        cframe * vector3New(hw, hh, hd),
        cframe * vector3New(-hw, hh, hd),
        cframe * vector3New(-hw, hh, -hd),
        cframe * vector3New(hw, hh, -hd),
        cframe * vector3New(hw, -hh, hd),
        cframe * vector3New(-hw, -hh, hd),
        cframe * vector3New(-hw, -hh, -hd),
        cframe * vector3New(hw, -hh, -hd)
    }
end

local function drawLine(line, p1, p2, vis, color)
    line.Visible = vis
    if vis then
        line.From = Vector2.new(p1.X, p1.Y)
        line.To = Vector2.new(p2.X, p2.Y)
        line.Color = color
    end
end

connections.ESPLoop = runService.RenderStepped:Connect(function()
    if not Toggles then return end
    local enabled = Toggles.ESPEnabled and Toggles.ESPEnabled.Value
    local boxEnabled = Toggles.ESPBox and Toggles.ESPBox.Value
    local showDisplayName = Toggles.ESPDisplayName and Toggles.ESPDisplayName.Value
    local showUsername = Toggles.ESPUsername and Toggles.ESPUsername.Value
    local highlightEnabled = Toggles.ESPHighlight and Toggles.ESPHighlight.Value
    local healthBarEnabled = Toggles.ESPHealthBar and Toggles.ESPHealthBar.Value
    
    local selectedFlags = Options.ESPFlags and Options.ESPFlags.Value or {}
    
    local boxColor = Options.BoxColor and Options.BoxColor.Value or Color3.new(1,1,1)
    local nameColor = Options.NameColor and Options.NameColor.Value or Color3.new(1,1,1)
    local flagColor = Options.FlagColor and Options.FlagColor.Value or Color3.new(0.6,0.6,1)
    local fillHighColor = Options.HighlightFill and Options.HighlightFill.Value or Color3.new(1,0,0)
    local outHighColor = Options.HighlightOutline and Options.HighlightOutline.Value or Color3.new(1,1,1)

    local boxTrans = 1 - (Options.BoxColor and Options.BoxColor.Transparency or 0)
    local nameTrans = 1 - (Options.NameColor and Options.NameColor.Transparency or 0)
    local flagTrans = 1 - (Options.FlagColor and Options.FlagColor.Transparency or 0)
    local fillHighTrans = Options.HighlightFill and Options.HighlightFill.Transparency or 0.5
    local outHighTrans = Options.HighlightOutline and Options.HighlightOutline.Transparency or 0
    
    for player, esp in pairs(ESP_INSTANCES) do
        local vis = false
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if enabled and char and hrp and hum and hum.Health > 0 then
            -- Highlight Logic
            if esp.highlight then
                esp.highlight.Enabled = highlightEnabled
                esp.highlight.Adornee = char
                esp.highlight.FillColor = fillHighColor
                esp.highlight.OutlineColor = outHighColor
                esp.highlight.FillTransparency = fillHighTrans
                esp.highlight.OutlineTransparency = outHighTrans
            end

            local pos, onScreen = currentCamera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                vis = true
                
                -- BOUNDARY CALCULATION
                local size = vector3New(4, 5, 4)
                local corners = getCorners3D(hrp.CFrame * cFrameNew(0, -0.5, 0), size)
                local s = {}
                local allCornersOnScreen = true
                local minX, maxX, minY, maxY
                
                for i = 1, 8 do
                    local sp, os = currentCamera:WorldToViewportPoint(corners[i])
                    s[i] = sp
                    if not os then allCornersOnScreen = false end
                    
                    if i == 1 then
                        minX, maxX, minY, maxY = sp.X, sp.X, sp.Y, sp.Y
                    else
                        if sp.X < minX then minX = sp.X end
                        if sp.X > maxX then maxX = sp.X end
                        if sp.Y < minY then minY = sp.Y end
                        if sp.Y > maxY then maxY = sp.Y end
                    end
                end

                -- 3D BOX Setup
                if boxEnabled and allCornersOnScreen then
                    -- Top lines (1-4), Bottom (5-8), Vert (9-12)
                    drawLine(esp.box[1], s[1], s[2], true, boxColor)
                    drawLine(esp.box[2], s[2], s[3], true, boxColor)
                    drawLine(esp.box[3], s[3], s[4], true, boxColor)
                    drawLine(esp.box[4], s[4], s[1], true, boxColor)
                    drawLine(esp.box[5], s[5], s[6], true, boxColor)
                    drawLine(esp.box[6], s[6], s[7], true, boxColor)
                    drawLine(esp.box[7], s[7], s[8], true, boxColor)
                    drawLine(esp.box[8], s[8], s[5], true, boxColor)
                    drawLine(esp.box[9], s[1], s[5], true, boxColor)
                    drawLine(esp.box[10], s[2], s[6], true, boxColor)
                    drawLine(esp.box[11], s[3], s[7], true, boxColor)
                    drawLine(esp.box[12], s[4], s[8], true, boxColor)
                    for i = 1, 12 do esp.box[i].Transparency = boxTrans end
                else
                    for i = 1, 12 do esp.box[i].Visible = false end
                end

                -- Health Bar Setup
                if healthBarEnabled then
                    local barX = minX - 5
                    local barHeight = maxY - minY
                    local healthPercent = hum.Health / hum.MaxHealth
                    esp.healthBar.Visible = true
                    esp.healthBar.From = Vector2.new(barX, minY)
                    esp.healthBar.To = Vector2.new(barX, maxY)
                    esp.healthBar.Color = Color3.new(0,0,0)
                    esp.healthBar.Transparency = boxTrans
                    esp.healthFill.Visible = true
                    esp.healthFill.From = Vector2.new(barX, maxY)
                    esp.healthFill.To = Vector2.new(barX, maxY - (barHeight * healthPercent))
                    esp.healthFill.Color = Color3.fromHSV(healthPercent * 0.3, 1, 1)
                    esp.healthFill.Transparency = boxTrans
                else
                    esp.healthBar.Visible = false
                    esp.healthFill.Visible = false
                end
                
                -- NAME ESP SETUP (On top)
                if showDisplayName or showUsername then
                    local nameStr = ""
                    if showDisplayName and showUsername then nameStr = player.DisplayName .. " (@" .. player.Name .. ")"
                    elseif showDisplayName then nameStr = player.DisplayName
                    elseif showUsername then nameStr = player.Name end
                    
                    esp.name.Visible = true
                    esp.name.Text = nameStr
                    esp.name.Center = true
                    esp.name.Position = Vector2.new(pos.X, minY - 18)
                    esp.name.Color = nameColor
                    esp.name.Transparency = nameTrans
                else
                    esp.name.Visible = false
                end

                -- FLAGS ESP SETUP (On the right)
                local startY = minY
                local startX = maxX + 5
                local playerData = player:FindFirstChild("PlayerData")
                local slotData = playerData and playerData:FindFirstChild("SlotData")
                
                for _, flag in ipairs({"Level", "Stand", "Style", "SubAbility"}) do
                    local drawing = esp.flags[flag:lower()]
                    local text = ""
                    if selectedFlags[flag] and slotData then
                        if flag == "Level" then
                            local l = slotData:FindFirstChild("Level")
                            if l then text = "Lvl: " .. tostring(l.Value) end
                        elseif flag == "Stand" then
                            local s = slotData:FindFirstChild("Stand")
                            if s then
                                local sVal = tostring(s.Value)
                                if not STAND_CACHE[sVal] then
                                    if sVal:sub(1,1) == "{" then
                                        local sc, p = pcall(function() return HttpService:JSONDecode(sVal) end)
                                        STAND_CACHE[sVal] = (sc and type(p) == "table" and p.Name) and tostring(p.Name) or "None"
                                    else
                                        STAND_CACHE[sVal] = sVal
                                    end
                                end
                                text = "Stand: " .. STAND_CACHE[sVal]
                            end
                        elseif flag == "Style" then
                            local fs = slotData:FindFirstChild("FightingStyle")
                            if fs then text = "Style: " .. tostring(fs.Value) end
                        elseif flag == "SubAbility" then
                            local sub = slotData:FindFirstChild("SubAbility")
                            if sub then text = "Sub: " .. tostring(sub.Value) end
                        end
                    end

                    if text ~= "" and drawing then
                        drawing.Visible = true
                        drawing.Text = text
                        drawing.Center = false
                        drawing.Position = Vector2.new(startX, startY)
                        drawing.Color = flagColor
                        drawing.Transparency = flagTrans
                        startY = startY + 12
                    else
                        drawing.Visible = false
                    end
                end
            end
        else
            if esp.highlight then esp.highlight.Enabled = false end
        end
        
        if not vis or not enabled then
            for i = 1, 12 do esp.box[i].Visible = false end
            esp.name.Visible = false
            for _, f in pairs(esp.flags) do f.Visible = false end
            esp.healthBar.Visible = false
            esp.healthFill.Visible = false
            if esp.highlight then esp.highlight.Enabled = false end
        end
    end
end)


