-- Shared logic for movement inside RenderStepped to avoid overlaps
connections.MovementLoop = runService.RenderStepped:Connect(function()
    if not rootPart or not Toggles then return end
    
    local flying = Toggles.FlyToggle and Toggles.FlyToggle.Value
    local speeding = Toggles.SpeedToggle and Toggles.SpeedToggle.Value
    
    local isTyping = (userInputService:GetFocusedTextBox() ~= nil)
    
    if flying then
        -- Fly logic
        local flightSpeed = Options.FlyValue.Value
        local dir = Vector3.zero
        local cam = currentCamera.CFrame
        if not isTyping then
            if keys[keyCode.W] then dir = dir + cam.LookVector end
            if keys[keyCode.S] then dir = dir - cam.LookVector end
            if keys[keyCode.A] then dir = dir - cam.RightVector end
            if keys[keyCode.D] then dir = dir + cam.RightVector end
            if keys[keyCode.Space] then dir = dir + vector3New(0, 1, 0) end
            if keys[keyCode.LeftControl] then dir = dir - vector3New(0, 1, 0) end
        end
        rootPart.Velocity = dir.Magnitude > 0 and dir.Unit * flightSpeed or Vector3.zero
        
    elseif speeding then
        -- Speed logic (only runs if fly is false)
        local speedValue = Options.SpeedValue.Value
        local dir = Vector3.zero
        local cam = currentCamera.CFrame
        if not isTyping then
            if keys[keyCode.W] then dir = dir + cam.LookVector end
            if keys[keyCode.S] then dir = dir - cam.LookVector end
            if keys[keyCode.A] then dir = dir - cam.RightVector end
            if keys[keyCode.D] then dir = dir + cam.RightVector end
        end
        -- Flat horizontal vector
        dir = vector3New(dir.X, 0, dir.Z)
        
        if dir.Magnitude > 0 then
            rootPart.Velocity = vector3New(dir.Unit.X * speedValue, rootPart.Velocity.Y, dir.Unit.Z * speedValue)
        end
    end
end)

