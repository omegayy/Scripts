local function Request(options)
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if requestFunc then
        return requestFunc(options)
    end
    return nil
end

local AIRightGroup = Tabs.AI:AddRightGroupbox('Response')
local responseLabel = AIRightGroup:AddLabel("Waiting...", true)

local function updateResponse(text)
    if responseLabel then
        responseLabel:SetText(text or "No response")
    end
end

local HttpService = game:GetService("HttpService")

local function sendToAI(msg)
    if not msg or msg == "" then updateResponse("Please enter a message"); return end
    updateResponse("Thinking... 🤔")
    
    local success, response = pcall(function()
        return Request({
            Url = "https://norberto-immodest-arythmically.ngrok-free.dev/chat",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({message = msg})
        })
    end)
    
    if success and response and response.Success then
        local success2, decoded = pcall(function() return HttpService:JSONDecode(response.Body) end)
        if success2 and decoded then
            updateResponse(decoded.reply or decoded.response or decoded.message or "No reply")
        else
            updateResponse("Error parsing response")
        end
    else
        updateResponse("Failed to connect to AI server.")
    end
end

AIGroup:AddButton({
    Text = 'Send to AI',
    Func = function() sendToAI(message) end
})


