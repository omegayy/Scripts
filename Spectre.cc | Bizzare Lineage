local playerStatsLabel
local lastStatText = ""

PlayersRight:AddButton('View Stats', function()
    if selectedPlayer then
        local flagText = "======== Main stats ========\n"
        local playerData = selectedPlayer:FindFirstChild("PlayerData")
        local slotData = playerData and playerData:FindFirstChild("SlotData")
        
        if slotData then
            local level = slotData:FindFirstChild("Level")
            if level then flagText = flagText .. "Level: " .. tostring(level.Value) .. "\n" end
            
            local stand = slotData:FindFirstChild("Stand")
            if stand then
                local standStr = tostring(stand.Value)
                local sName = "None"
                if standStr:sub(1,1) == "{" then
                    local sc, parsed = pcall(function() return HttpService:JSONDecode(standStr) end)
                    if sc and type(parsed) == "table" and parsed.Name then
                        sName = tostring(parsed.Name)
                    end
                else
                    sName = standStr
                end
                flagText = flagText .. "Stand: " .. sName .. "\n"
            end
            
            local fstyle = slotData:FindFirstChild("FightingStyle")
            if fstyle then flagText = flagText .. "Style: " .. tostring(fstyle.Value) .. "\n" end
            
            local subAb = slotData:FindFirstChild("SubAbility")
            if subAb then flagText = flagText .. "Sub: " .. tostring(subAb.Value) .. "\n" end

            local money = slotData:FindFirstChild("Money")
            if money then flagText = flagText .. "Money: $" .. tostring(money.Value) .. "\n" end
        else
            flagText = flagText .. "No PlayerData found.\n"
        end

        -- Stand Storage
        flagText = flagText .. "\n======== Stand Storage ========\n"
        
        -- 1. Equipped Stand
        local equippedStand = slotData and slotData:FindFirstChild("Stand")
        if equippedStand then
            local standStr = tostring(equippedStand.Value)
            if standStr:sub(1,1) == "{" then
                local sc, parsed = pcall(function() return HttpService:JSONDecode(standStr) end)
                if sc and type(parsed) == "table" and parsed.Name then
                    flagText = flagText .. "Stand: " .. tostring(parsed.Name) .. " (Equipped)\n"
                    if parsed.Skin and parsed.Skin ~= "" then flagText = flagText .. "  Skin: " .. tostring(parsed.Skin) .. "\n" end
                    if parsed.Trait and parsed.Trait ~= "" then flagText = flagText .. "  Trait: " .. tostring(parsed.Trait) .. "\n" end
                    if parsed.Speed then flagText = flagText .. "  Speed: " .. tostring(parsed.Speed) .. "\n" end
                    if parsed.Strength then flagText = flagText .. "  Strength: " .. tostring(parsed.Strength) .. "\n" end
                    if parsed.Specialty then flagText = flagText .. "  Specialty: " .. tostring(parsed.Specialty) .. "\n" end
                    flagText = flagText .. "  ------------------\n"
                end
            end
        end

        -- 2. Stored Stands
        local standStorage = playerData and playerData:FindFirstChild("StandStorage")
        if standStorage then
            local sc, parsed = pcall(function() return HttpService:JSONDecode(standStorage.Value) end)
            if sc and type(parsed) == "table" then
                if #parsed == 0 then
                    if not equippedStand then flagText = flagText .. "Empty\n" end
                else
                    for i, s in ipairs(parsed) do
                        if s.Name then
                            flagText = flagText .. "Stand: " .. tostring(s.Name) .. "\n"
                            if s.Skin and s.Skin ~= "" then flagText = flagText .. "  Skin: " .. tostring(s.Skin) .. "\n" end
                            if s.Trait and s.Trait ~= "" then flagText = flagText .. "  Trait: " .. tostring(s.Trait) .. "\n" end
                            if s.Speed then flagText = flagText .. "  Speed: " .. tostring(s.Speed) .. "\n" end
                            if s.Strength then flagText = flagText .. "  Strength: " .. tostring(s.Strength) .. "\n" end
                            if s.Specialty then flagText = flagText .. "  Specialty: " .. tostring(s.Specialty) .. "\n" end
                            
                            if i < #parsed then
                                flagText = flagText .. "  ------------------\n"
                            end
                        end
                    end
                end
            else
                flagText = flagText .. "Failed to parse storage.\n"
            end
        else
            flagText = flagText .. "No Storage found.\n"
        end

        -- Inventory
        flagText = flagText .. "\n======== Inventory ========\n"
        local inventory = slotData and slotData:FindFirstChild("Inventory")
        if inventory then
            local sc, parsed = pcall(function() return HttpService:JSONDecode(inventory.Value) end)
            if sc and type(parsed) == "table" then
                if #parsed == 0 then
                    flagText = flagText .. "Empty\n"
                else
                    -- Sort Alphabetically
                    table.sort(parsed, function(a, b)
                        return (a.Name or ""):lower() < (b.Name or ""):lower()
                    end)

                    for _, item in ipairs(parsed) do
                        if item.Name then
                            local line = "- " .. item.Name
                            if item.Amount then
                                line = line .. " x" .. tostring(item.Amount)
                            end
                            flagText = flagText .. line .. "\n"
                        end
                    end
                end
            else
                flagText = flagText .. "Failed to parse.\n"
            end
        else
            flagText = flagText .. "No Inventory found.\n"
        end

        playerStatsLabel:SetText(flagText)
        lastStatText = flagText
    end
end)

